# Base de données (PostgreSQL + PostGIS)
DATABASE_URL="postgresql://tracking:tracking@localhost:5432/tracking_app?schema=public"

# Serveur
PORT=3000
FRONTEND_URL="http://localhost:5173"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES="30d"

# Essai administrateur
TRIAL_DEFAULT_DURATION_DAYS=14
TRIAL_EXPIRING_SOON_DAYS=3

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASSWORD="change-me"
SMTP_FROM="Tracking App <no-reply@example.com>"

# SMS / WhatsApp (Twilio)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="change-me"
TWILIO_SMS_FROM="+10000000000"
TWILIO_WHATSAPP_FROM="whatsapp:+10000000000"
